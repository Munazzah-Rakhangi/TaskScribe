# Copy to .env and fill in values

DATABASE_URL=sqlite:///./app.db
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: SMTP for password reset and deadline reminder emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your-email@gmail.com

# Optional overrides
# JWT_SECRET=change-me-in-production
# FRONTEND_URL=http://localhost:3000
# API_BASE_URL=http://127.0.0.1:8003

# Optional: Google OAuth (Sign in with Google)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://127.0.0.1:8003/auth/google/callback (or your API_BASE_URL + /auth/google/callback)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
